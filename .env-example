# =========================
# ESP32 / OpenCV stream
# =========================
ESP32_IP=192.168.1.83
MJPEG_URL=http://192.168.1.83:81/stream
OPENCV_STREAM_URL=http://opencv:5001/stream

# =========================
# MQTT
# =========================
MQTT_BROKER=mqtt
MQTT_PORT=1883
TOPIC_PAN=esp32cam/cmd/pan
TOPIC_TILT=esp32cam/cmd/tilt
TOPIC_MODE=esp32cam/cmd/mode
FACES_TOPIC=esp32cam/status/faces
STATUS_FACES_TOPIC=esp32cam/status/faces
TOL=20
STEP=2

# =========================
# Web UI default state
# =========================
PAN_START=90
TILT_START=90

# =========================
# Authentication / users
# =========================
FLASK_SECRET_KEY=change-this-secret
USER_DB_PATH=/app/users.db

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_VIEWER_USERNAME=viewer
DEFAULT_VIEWER_PASSWORD=viewer123

# OpenCV performance tuning
DETECT_EVERY_N=2
DETECT_RESIZE=0.5
JPEG_QUALITY=70
DRAW_OVERLAY=1
