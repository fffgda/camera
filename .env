# =========================
# ESP32 / OpenCV stream
# =========================
ESP32_IP=192.168.1.43
MJPEG_URL=http://192.168.1.43:81/stream
OPENCV_STREAM_URL=http://opencv:5001/stream

# =========================
# MQTT
# =========================
MQTT_BROKER=mqtt
MQTT_PORT=1883
TOPIC_PAN=esp32cam/cmd/pan
TOPIC_TILT=esp32cam/cmd/tilt
TOPIC_MODE=esp32cam/cmd/mode
FACES_TOPIC=esp32cam/status/faces
STATUS_FACES_TOPIC=esp32cam/status/faces
PEOPLE_TOPIC=esp32cam/status/people
STATUS_PEOPLE_TOPIC=esp32cam/status/people
TOL=20
STEP=2

# =========================
# Web UI default state
# =========================
PAN_START=90
TILT_START=90

# =========================
# Authentication / users
# =========================
FLASK_SECRET_KEY=change-this-secret
USER_DB_PATH=/app/users.db

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_VIEWER_USERNAME=viewer
DEFAULT_VIEWER_PASSWORD=viewer123

# =========================
# YOLO detection settings
# =========================
YOLO_CONF=0.6
DETECT_EVERY_N=3
DETECT_RESIZE=0.4
JPEG_QUALITY=50
DRAW_OVERLAY=1

# =========================
# Alert settings
# =========================
ALERT_THRESHOLD=5
ALERT_COOLDOWN=300
ALERT_WEBHOOK_URL=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_EMAIL_TO=
